{
  "seed": 42,
  "n_sample": 100,
  "epochs": 1,
  "batch_size": 16,
  "d_model": 96,
  "n_heads": 4,
  "encoder_layers": 3,
  "decoder_layers": 2,
  "dropout": 0.1,
  "lr": 0.0002,
  "weight_decay": 0.0001,
  "early_stopping_patience": 4,
  "min_calibration_rows": 50,
  "gradient_clip_norm": 1.0,
  "max_context_siblings": 8,
  "max_context_unrelated_labs": 16,
  "max_tokens": 128,
  "lab_history_depth": 3,
  "expanded_features": true,
  "enable_vitals": true,
  "enable_diseases": true,
  "enable_medications": true,
  "enable_clinical_activity": true,
  "enable_administrative": true,
  "use_event_cache": true,
  "max_train_examples": 40,
  "max_val_examples": 30,
  "max_test_examples": 30,
  "cv_high_weight": 0.8,
  "cv_low_weight": 0.2,
  "cv_percentile": 75.0,
  "eval_thresholds": [
    0.5,
    0.6,
    0.7,
    0.8,
    0.9,
    0.95,
    0.99
  ],
  "min_train_rows": 20,
  "min_val_rows": 10,
  "min_test_rows": 10,
  "background_allowlist": [
    "age",
    "sex_numeric",
    "days_in_admission",
    "prev_sbp",
    "prev_dbp",
    "prev_pulse",
    "prev_storation",
    "days_since_prev_sbp",
    "days_since_prev_dbp",
    "days_since_prev_pulse",
    "days_since_prev_storation"
  ]
}